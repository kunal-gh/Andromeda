# ═══════════════════════════════════════════════════════════════
# ANDROMEDA — Enterprise AI Agent Platform
# Configuration Template  |  copy to .env and fill in your keys
# ═══════════════════════════════════════════════════════════════

# ── LLM Provider ────────────────────────────────────────────────
# Choose one of: gemini | groq | openai | mock
# "mock" uses a local heuristic extractor — no API key needed.
LLM_PROVIDER=gemini

# Gemini (recommended — free tier at aistudio.google.com/apikey)
GEMINI_API_KEY=your-gemini-api-key
GEMINI_MODEL=gemini-2.0-flash

# Groq (fast free inference — console.groq.com/keys)
GROQ_API_KEY=your-groq-api-key
GROQ_MODEL=llama-3.3-70b-versatile

# OpenAI (platform.openai.com/api-keys)
OPENAI_API_KEY=your-openai-api-key
OPENAI_MODEL=gpt-4o-mini

# ── Database ─────────────────────────────────────────────────────
DATABASE_URL=sqlite:////app/data/andromeda.db

# ── Application ──────────────────────────────────────────────────
# Fixed reference date for demo reproducibility (all CRM orders relative to this)
BUSINESS_TODAY=2025-01-15
FRONTEND_ORIGIN=http://localhost:3000
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000

# ── Agent Architecture ────────────────────────────────────────────
# AGENT_MODE: "graph" = LangGraph pipeline | "legacy" = original sequential runner
AGENT_MODE=graph
# TOOL_MODE: "local" = SQLAlchemy direct | "mcp" = MCP servers (Phase 2)
TOOL_MODE=local
# AGENT_ARCHITECTURE: "single" = one graph | "multi" = Supervisor+Workers (Phase 6)
AGENT_ARCHITECTURE=single

# ── RAG / Vector Database (Phase 3) ───────────────────────────────
RAG_ENABLED=false
CHROMA_HOST=localhost
CHROMA_PORT=8001
# EMBEDDING_PROVIDER: "local" = sentence-transformers (free) | "openai" = API
EMBEDDING_PROVIDER=local
RAG_TOP_K=3
RAG_SCORE_THRESHOLD=0.65

# ── Observability — Langfuse (Phase 5) ────────────────────────────
# Free tier at cloud.langfuse.com — no credit card needed
LANGFUSE_PUBLIC_KEY=pk-lf-your-key
LANGFUSE_SECRET_KEY=sk-lf-your-key
LANGFUSE_HOST=https://cloud.langfuse.com

# ── MCP Servers (Phase 2, when TOOL_MODE=mcp) ─────────────────────
CRM_MCP_SERVER_URL=http://crm-mcp:8100
POLICY_MCP_SERVER_URL=http://policy-mcp:8102
